# ==============================
# LUXÉA Beauty — Environment Variables
# copy ไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง
# ==============================

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/luxea_beauty"

# Clerk Authentication
# สมัครได้ที่ https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Omise Payment
# สมัครได้ที่ https://omise.co
NEXT_PUBLIC_OMISE_PUBLIC_KEY=pkey_test_xxxxxxxx
OMISE_SECRET_KEY=skey_test_xxxxxxxx

# Resend Email
# สมัครได้ที่ https://resend.com
RESEND_API_KEY=re_xxxxxxxx

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
