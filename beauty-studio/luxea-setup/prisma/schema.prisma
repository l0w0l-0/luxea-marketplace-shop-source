// prisma/schema.prisma
// รัน: npx prisma db push เพื่อสร้างตารางในฐานข้อมูล

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==============================
// USER
// ==============================
model User {
  id             String    @id @default(cuid())
  clerkId        String    @unique
  email          String    @unique
  name           String?
  phone          String?
  loyaltyPoints  Int       @default(0)
  createdAt      DateTime  @default(now())

  addresses      Address[]
  orders         Order[]
  reviews        Review[]
  wishlists      Wishlist[]
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  label       String?  // บ้าน, ที่ทำงาน
  name        String
  phone       String
  address     String
  district    String
  province    String
  postalCode  String
  isDefault   Boolean  @default(false)

  user        User     @relation(fields: [userId], references: [id])
  orders      Order[]
}

// ==============================
// PRODUCT
// ==============================
model Product {
  id          String         @id @default(cuid())
  name        String
  description String?
  ingredients String?
  howToUse    String?
  category    String
  price       Decimal
  stock       Int            @default(0)
  isActive    Boolean        @default(true)
  images      String[]
  createdAt   DateTime       @default(now())

  colors      ProductColor[]
}

model ProductColor {
  id          String   @id @default(cuid())
  productId   String
  colorCode   String   // LP003
  name        String   // Rosy Pink
  hex         String   // #D96483
  finish      String?  // Matte, Glossy, Satin
  undertone   String?  // Cool, Warm, Neutral
  stock       Int      @default(0)

  product     Product      @relation(fields: [productId], references: [id])
  orderItems  OrderItem[]
  reviews     Review[]
  wishlists   Wishlist[]
}

// ==============================
// ORDER
// ==============================
model Order {
  id            String      @id @default(cuid())
  userId        String
  addressId     String
  subtotal      Decimal
  shippingFee   Decimal     @default(0)
  discount      Decimal     @default(0)
  total         Decimal
  status        OrderStatus @default(PENDING_PAYMENT)
  paymentMethod String?
  couponCode    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user          User        @relation(fields: [userId], references: [id])
  address       Address     @relation(fields: [addressId], references: [id])
  items         OrderItem[]
  payment       Payment?
}

model OrderItem {
  id             String       @id @default(cuid())
  orderId        String
  productColorId String
  quantity       Int
  unitPrice      Decimal

  order          Order        @relation(fields: [orderId], references: [id])
  productColor   ProductColor @relation(fields: [productColorId], references: [id])
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
}

// ==============================
// PAYMENT
// ==============================
model Payment {
  id            String   @id @default(cuid())
  orderId       String   @unique
  transactionId String?
  method        String   // PromptPay, CreditCard
  amount        Decimal
  status        String   // SUCCESS, FAILED, PENDING
  paidAt        DateTime?

  order         Order    @relation(fields: [orderId], references: [id])
}

// ==============================
// REVIEW
// ==============================
model Review {
  id             String       @id @default(cuid())
  userId         String
  productColorId String
  rating         Int          // 1-5
  comment        String?
  skinTone       String?      // ผิวขาว, ผิวสองสี, ผิวแทน
  createdAt      DateTime     @default(now())

  user           User         @relation(fields: [userId], references: [id])
  productColor   ProductColor @relation(fields: [productColorId], references: [id])
}

// ==============================
// WISHLIST
// ==============================
model Wishlist {
  id             String       @id @default(cuid())
  userId         String
  productColorId String
  createdAt      DateTime     @default(now())

  user           User         @relation(fields: [userId], references: [id])
  productColor   ProductColor @relation(fields: [productColorId], references: [id])

  @@unique([userId, productColorId])
}
