generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProductCategory {
  LIPSTICK
  FOUNDATION
  BLUSH
  EYESHADOW
  HIGHLIGHTER
  CONTOUR
  SKINCARE
}

enum Undertone {
  COOL
  WARM
  NEUTRAL
}

enum Finish {
  MATTE
  GLOSSY
  SATIN
  SHIMMER
}

enum Coverage {
  LIGHT
  MEDIUM
  FULL
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum CartStatus {
  ACTIVE
  CONVERTED
  EXPIRED
  ABANDONED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum OrderPaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  PROMPTPAY
  WALLET
}

enum LoyaltyTransactionReason {
  PURCHASE
  REDEEM_DISCOUNT
  REDEEM_SHIPPING
  BOTTLE_RECYCLE
  REFERRAL
}

model User {
  id        String     @id @default(uuid()) @db.Uuid
  email     String     @unique @db.VarChar(255)
  name      String     @db.VarChar(255)
  skinTone  String?    @map("skin_tone") @db.VarChar(100)
  undertone Undertone? @map("undertone")
  role      UserRole   @default(CUSTOMER)
  deletedAt DateTime?  @map("deleted_at")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  carts               Cart[]
  orders              Order[]
  loyalty             Loyalty?
  loyaltyTransactions LoyaltyTransaction[]

  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

model Product {
  id          String          @id @default(uuid()) @db.Uuid
  name        String          @db.VarChar(255)
  category    ProductCategory
  basePrice   Decimal         @map("base_price") @db.Decimal(12, 2)
  description String          @db.Text
  videoUrl    String?         @map("video_url") @db.Text
  avgRating   Decimal?        @map("avg_rating") @db.Decimal(3, 2)
  reviewCount Int             @default(0) @map("review_count")
  isActive    Boolean         @default(true) @map("is_active")
  deletedAt   DateTime?       @map("deleted_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  colors         ProductColor[]
  inventoryItems Inventory[]
  cartItems      CartItem[]
  orderItems     OrderItem[]

  @@index([category, isActive])
  @@index([isActive, deletedAt])
  @@index([createdAt])
  @@index([basePrice])
  @@map("products")
}

model ProductColor {
  id         String     @id @default(uuid()) @db.Uuid
  productId  String     @map("product_id") @db.Uuid
  colorName  String     @map("color_name") @db.VarChar(120)
  hex        String     @db.VarChar(7)
  rgb        String     @db.VarChar(32)
  undertone  Undertone
  finish     Finish
  coverage   Coverage
  opacityPct Int        @map("opacity_pct")
  deletedAt  DateTime?  @map("deleted_at")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  product        Product      @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  inventoryItems Inventory[]
  cartItems      CartItem[]
  orderItems     OrderItem[]

  @@unique([productId, colorName])
  @@index([productId])
  @@index([hex])
  @@index([undertone, finish])
  @@index([deletedAt])
  @@map("product_colors")
}

model Inventory {
  id                String    @id @default(uuid()) @db.Uuid
  productId         String    @map("product_id") @db.Uuid
  colorId           String?   @map("color_id") @db.Uuid
  stockQty          Int       @default(0) @map("stock_qty")
  reservedQty       Int       @default(0) @map("reserved_qty")
  lowStockThreshold Int       @default(10) @map("low_stock_threshold")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  product Product       @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  color   ProductColor? @relation(fields: [colorId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([productId, colorId])
  @@index([productId])
  @@index([colorId])
  @@index([stockQty])
  @@index([lowStockThreshold])
  @@index([deletedAt])
  @@map("inventory")
}

model Cart {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String?    @map("user_id") @db.Uuid
  sessionId String?    @map("session_id") @db.VarChar(255)
  status    CartStatus @default(ACTIVE)
  expiresAt DateTime?  @map("expires_at")
  deletedAt DateTime?  @map("deleted_at")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  user  User?      @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  items CartItem[]

  @@index([userId])
  @@index([sessionId])
  @@index([status, expiresAt])
  @@index([deletedAt])
  @@map("carts")
  /// DB-level CHECK constraint required in SQL migration:
  /// CHECK ("user_id" IS NOT NULL OR "session_id" IS NOT NULL)
}

model CartItem {
  id        String    @id @default(uuid()) @db.Uuid
  cartId    String    @map("cart_id") @db.Uuid
  productId String    @map("product_id") @db.Uuid
  colorId   String?   @map("color_id") @db.Uuid
  quantity  Int
  unitPrice Decimal   @map("unit_price") @db.Decimal(12, 2)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  cart    Cart          @relation(fields: [cartId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  color   ProductColor? @relation(fields: [colorId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([cartId])
  @@index([productId])
  @@index([colorId])
  @@unique([cartId, productId, colorId])
  @@map("cart_items")
}

model Order {
  id                    String             @id @default(uuid()) @db.Uuid
  userId                String             @map("user_id") @db.Uuid
  status                OrderStatus        @default(PENDING_PAYMENT)
  subtotal              Decimal            @db.Decimal(12, 2)
  shippingFee           Decimal            @map("shipping_fee") @db.Decimal(12, 2)
  discount              Decimal            @default(0) @db.Decimal(12, 2)
  total                 Decimal            @db.Decimal(12, 2)
  paymentMethod         OrderPaymentMethod @map("payment_method")
  paymentReferenceToken String?            @map("payment_reference_token") @db.VarChar(255)
  idempotencyKey        String?            @map("idempotency_key") @db.VarChar(255)
  deletedAt             DateTime?          @map("deleted_at")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  user                User                 @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  items               OrderItem[]
  loyaltyTransactions LoyaltyTransaction[]

  @@unique([idempotencyKey])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("orders")
}

model OrderItem {
  id        String    @id @default(uuid()) @db.Uuid
  orderId   String    @map("order_id") @db.Uuid
  productId String    @map("product_id") @db.Uuid
  colorId   String?   @map("color_id") @db.Uuid
  quantity  Int
  /// Snapshot of price at checkout time. Never recalculate from Product.basePrice.
  unitPrice Decimal   @map("unit_price") @db.Decimal(12, 2)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  order   Order         @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  color   ProductColor? @relation(fields: [colorId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([orderId])
  @@index([productId])
  @@index([colorId])
  @@map("order_items")
}

model Loyalty {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @unique @map("user_id") @db.Uuid
  pointsBalance Int       @default(0) @map("points_balance")
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([deletedAt])
  @@map("loyalty")
}

model LoyaltyTransaction {
  id           String                   @id @default(uuid()) @db.Uuid
  userId       String                   @map("user_id") @db.Uuid
  orderId      String?                  @map("order_id") @db.Uuid
  pointsChange Int                      @map("points_change")
  reason       LoyaltyTransactionReason
  createdAt    DateTime                 @default(now()) @map("created_at")
  updatedAt    DateTime                 @updatedAt @map("updated_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([userId])
  @@index([orderId])
  @@index([reason, createdAt])
  @@index([userId, createdAt])
  @@map("loyalty_transactions")
}
